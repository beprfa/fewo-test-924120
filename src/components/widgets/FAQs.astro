---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Faqs as Props } from '~/types';

const {
  title = '',
  subtitle = '',
  tagline = '',
  items = [],
  columns = 2,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <div class:list={[
    'grid gap-4 md:gap-6',
    columns === 1 ? 'max-w-4xl mx-auto' : 'md:grid-cols-2',
  ]}>
    {items.map(({ title, description }) => (
      <details class="group border border-gray-200 dark:border-slate-700 rounded-lg">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 font-semibold text-lg dark:text-white select-none">
          <span>{title}</span>
          <svg class="w-5 h-5 text-primary shrink-0 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <div class="px-5 pb-4 text-muted dark:text-slate-400">
          {description}
        </div>
      </details>
    ))}
  </div>
</WidgetWrapper>
