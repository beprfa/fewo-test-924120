---
import Layout from '~/layouts/PageLayoutEn.astro';
import { Icon } from 'astro-icon/components';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import AvailabilityCalendar from '~/components/AvailabilityCalendar.astro';

import ImageCarousel from '~/components/ImageCarousel.astro';

import alpenpanorama_1 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-1.jpg';
import alpenpanorama_2 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-2.jpg';
import alpenpanorama_3 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-3.jpg';
import alpenpanorama_4 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-4.jpg';
import alpenpanorama_5 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-5.jpg';
import alpenpanorama_6 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-6.jpg';
import alpenpanorama_7 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-7.jpg';
import alpenpanorama_8 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-8.jpg';

import bergwiese_1 from '~/assets/images/apartments/bergwiese/bergwiese-1.jpg';
import bergwiese_2 from '~/assets/images/apartments/bergwiese/bergwiese-2.jpg';
import bergwiese_3 from '~/assets/images/apartments/bergwiese/bergwiese-3.jpg';
import bergwiese_4 from '~/assets/images/apartments/bergwiese/bergwiese-4.jpg';
import bergwiese_5 from '~/assets/images/apartments/bergwiese/bergwiese-5.jpg';
import bergwiese_6 from '~/assets/images/apartments/bergwiese/bergwiese-6.jpg';

import lh1 from '~/assets/images/landhaus/bauernhof-01.jpg';
import lh2 from '~/assets/images/landhaus/bauernhof-02.jpg';
import lh3 from '~/assets/images/landhaus/bauernhof-03.jpg';
import lh4 from '~/assets/images/landhaus/bauernhof-04.jpg';
import lh5 from '~/assets/images/landhaus/bauernhof-05.jpg';
import lh6 from '~/assets/images/landhaus/bauernhof-06.jpg';

const alpenpanoramaImages = [
  { src: alpenpanorama_1, alt: 'Alpenpanorama 1' },
  { src: alpenpanorama_2, alt: 'Alpenpanorama 2' },
  { src: alpenpanorama_3, alt: 'Alpenpanorama 3' },
  { src: alpenpanorama_4, alt: 'Alpenpanorama 4' },
  { src: alpenpanorama_5, alt: 'Alpenpanorama 5' },
  { src: alpenpanorama_6, alt: 'Alpenpanorama 6' },
  { src: alpenpanorama_7, alt: 'Alpenpanorama 7' },
  { src: alpenpanorama_8, alt: 'Alpenpanorama 8' },
];

const bergwieseImages = [
  { src: bergwiese_1, alt: 'Bergwiese 1' },
  { src: bergwiese_2, alt: 'Bergwiese 2' },
  { src: bergwiese_3, alt: 'Bergwiese 3' },
  { src: bergwiese_4, alt: 'Bergwiese 4' },
  { src: bergwiese_5, alt: 'Bergwiese 5' },
  { src: bergwiese_6, alt: 'Bergwiese 6' },
];

const landhausImages = [
  { src: lh1, alt: 'Musterhaus Sonnenschein Landhaus' },
  { src: lh2, alt: 'Musterhaus Sonnenschein Garten' },
  { src: lh3, alt: 'Musterhaus Sonnenschein Terrasse' },
  { src: lh4, alt: 'Musterhaus Sonnenschein Umgebung' },
  { src: lh5, alt: 'Musterhaus Sonnenschein Aussicht' },
  { src: lh6, alt: 'Musterhaus Sonnenschein Eingang' },
];

const metadata = {
  title: 'Musterhaus Sonnenschein – Holiday Apartments in Aschau im Chiemgau',
  ignoreTitleTemplate: true,
};
---

<!-- BFW-352: tenant slug + public API base URL for the AvailabilityCalendar widget. -->
<script is:inline define:vars={{ tenantSlug: '924120', apiBase: 'http://localhost:9080' }}>
  window.MFWS_TENANT_SLUG = tenantSlug;
  window.MFWS_PUBLIC_API_BASE_URL = apiBase;
</script>

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'secondary',
        text: 'Booking Request',
        href: '/en/contact',
        icon: 'tabler:mail',
      },
      { variant: 'primary', text: 'View Apartments', href: '#apartments' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Musterhaus Sonnenschein – Holiday Apartments in Aschau im Chiemgau' }}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-white">Willkommen in unserer Ferienwohnung</span>
    </Fragment>

    <Fragment slot="subtitle">
      Erholung pur am Chiemsee
    </Fragment>
  </Hero>

  <!-- Apartments Section *************** -->

  <section id="apartments" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Holiday Apartments</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">Your Holiday Apartments in Aschau im Chiemgau</h2>
        <p class="text-lg text-muted dark:text-slate-400">
          Nichtraucher-Haus. Haustiere auf Anfrage. Parkplatz vorhanden.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-lg text-default dark:text-slate-300 mb-8">
        <span class="flex items-center gap-1.5"><Icon name="tabler:car" class="w-4 h-4" /> Parking</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:trees" class="w-4 h-4" /> Garden</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sun" class="w-4 h-4" /> Terrace</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:flame" class="w-4 h-4" /> BBQ Area</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:mood-kid" class="w-4 h-4" /> Children welcome</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:paw" class="w-4 h-4" /> Pets allowed</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sparkles" class="w-4 h-4" /> 2025 renoviert</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={alpenpanoramaImages} id="alpenpanorama" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Alpenpanorama</h3>
            <p class="text-sm text-muted dark:text-slate-400 mb-3">Unsere größte Wohnung im Erdgeschoss mit schönem Blick auf die Alpen. Ideal für Familien.</p>
            <p class="text-sm font-semibold text-primary mb-3">From 60 € / night (1 pers.) · 75 € / night (2 pers.) · incl. 7% VAT</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-3.5 h-3.5" /> 110 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-3.5 h-3.5" /> Living room</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Bedroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Kitchen</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bathroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Shower</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Double bed</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Single bed</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> Wi-Fi</span>
            </div>
            <AvailabilityCalendar apartment="alpenpanorama" id="alpenpanorama" />
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={bergwieseImages} id="bergwiese" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Bergwiese</h3>
            <p class="text-sm text-muted dark:text-slate-400 mb-3">Gemütliche Wohnung im Erdgeschoss mit Blick auf den Garten. Ideal für eine Auszeit zu zweit.</p>
            <p class="text-sm font-semibold text-primary mb-3">From 45 € / night (1 pers.) · 60 € / night (2 pers.) · incl. 7% VAT</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-3.5 h-3.5" /> 20 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-3.5 h-3.5" /> Living room</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Bedroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Kitchen</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bathroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bathtub</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Double bed</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Shower</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> Wi-Fi</span>
            </div>
            <AvailabilityCalendar apartment="bergwiese" id="bergwiese" />
          </div>
        </div>

      </div>

      <div class="text-center mt-8">
        <a href="/en/contact" class="btn btn-secondary font-semibold bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-6 py-3 rounded-full inline-block">Booking Request</a>
      </div>
    </div>
  </section>

  <!-- Welcome Section **************** -->

  <section id="the-estate" class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-8 md:mb-12">
        <p class="text-base text-primary dark:text-blue-200 font-bold tracking-wide uppercase mb-2">Welcome to Musterhaus Sonnenschein</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tighter font-heading dark:text-gray-200">Your Home in Aschau im Chiemgau</h2>
      </div>
      <div class="md:flex md:flex-row-reverse md:gap-16">
        <div class="md:basis-1/2 self-center mb-8 md:mb-0">
          <p class="text-lg dark:text-slate-400">
            Direkt am See gelegen mit Blick auf die Alpen. Wanderwege, Radwege und Schifffahrt in unmittelbarer Nähe.
          </p>
        </div>
        <div class="md:basis-1/2">
          <div class="rounded-lg overflow-hidden shadow-lg">
            <ImageCarousel images={landhausImages} id="landhaus" imageClass="w-full aspect-[3/2] object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Getting Here Section *************** -->

  <section id="getting-here" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Getting Here</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">How to Reach Us</h2>
      </div>

      <!-- %%%ANREISE_MAP_EN_START%%% -->
      <div class="text-center mb-6">
        <p class="text-lg text-default dark:text-slate-300">Bergstraße 7, 83229 Aschau im Chiemgau</p>
      </div>

      <div class="rounded-lg overflow-hidden mx-auto mb-6" style="aspect-ratio: 16/9; max-width: 900px;">
        <iframe
          title="Location of Sonnenhof Alpenblick"
          width="100%"
          height="100%"
          style="border: 0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.openstreetmap.org/export/embed.html?bbox=12.3050%2C47.7650%2C12.3400%2C47.7850&layer=mapnik&marker=47.7750%2C12.3230"
        ></iframe>
      </div>

      <div class="text-center">
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=Bergstraße+7,+83229+Aschau im Chiemgau"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary font-semibold bg-primary text-white border-primary hover:bg-secondary hover:border-secondary px-6 py-3 rounded-full inline-block"
        >
          Plan Route
        </a>
      </div>
      <!-- %%%ANREISE_MAP_EN_END%%% -->
    </div>
  </section>

  <!-- FAQs Widget ******************* -->

  {/* %%%FAQ_ITEMS_EN_START%%% */}
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Here you will find answers to the most important questions about your stay at Musterhaus Sonnenschein."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'When is check-in and check-out?',
        description:
          'Check-in is possible between 3:00 PM and 6:00 PM, check-out between 8:00 AM and 10:00 AM. Different times can be arranged upon request.',
      },
      {
        title: 'Is parking available?',
        description:
          'Yes, free parking spaces are available directly at the house.',
      },
      {
        title: 'Are pets allowed?',
        description:
          'Please contact us in advance if you would like to bring a pet. We will certainly find a solution.',
      },
      {
        title: 'How far is it to Lake Chiemsee?',
        description:
          'Lake Chiemsee is approximately 15 minutes away by car. The Kampenwand cable car and the center of Aschau are also quickly reachable.',
      },
      {
        title: 'Are children welcome?',
        description:
          'Of course! A crib and an extra bed are available on request. Please let us know when booking if you need one.',
      },
      {
        title: 'How can I book?',
        description:
          'Simply send us an inquiry via our contact form or by email to nicole.neckermann@icloud.com. We will get back to you as soon as possible.',
      },
    ]}
  />
  {/* %%%FAQ_ITEMS_EN_END%%% */}

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'secondary',
        text: 'Booking Request',
        href: '/en/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Your Aschau im Chiemgau&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Holiday Awaits</span>
    </Fragment>

    <Fragment slot="subtitle">
      Secure your preferred dates at Musterhaus Sonnenschein. <br class="hidden md:inline" />
      We look forward to your inquiry!
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-100 dark:bg-slate-800"></div>
    </Fragment>
  </CallToAction>
</Layout>
